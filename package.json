{
  "name": "@miridius/how",
  "version": "0.1.0",
  "description": "Ask Claude for a shell command, edit it, run it, keep it in your history.",
  "type": "module",
  "license": "MIT",
  "author": "miridius",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miridius/how.git"
  },
  "homepage": "https://github.com/miridius/how#readme",
  "bugs": "https://github.com/miridius/how/issues",
  "keywords": [
    "cli",
    "bun",
    "claude",
    "anthropic",
    "llm",
    "shell",
    "ai",
    "natural-language"
  ],
  "bin": {
    "how-bin": "./src/how.ts",
    "how-init": "./src/init.ts"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "engines": {
    "bun": ">=1.2.4"
  },
  "packageManager": "bun@1.3.3",
  "scripts": {
    "dev": "bun run src/how.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "check": "bun run typecheck && bun run lint && bun test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.65.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@types/bun": "latest",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
